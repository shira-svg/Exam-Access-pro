rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.subscriptionType == 'admin' ||
        request.auth.token.email == "shira@lomdot.org" ||
        request.auth.token.email == "shiraroth.z@gmail.com"
      );
    }

    // User Profiles
    match /users/{email} {
      allow read: if (isAuthenticated() && request.auth.token.email == email) || isAdmin();
      allow create: if isAuthenticated() && request.auth.token.email == email;
      allow update: if (isAuthenticated() && request.auth.token.email == email) || isAdmin();
    }

    // Tests
    match /tests/{testId} {
      allow read: if true; // Publicly readable for students
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.ownerEmail == request.auth.token.email || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.ownerEmail == request.auth.token.email || isAdmin());
    }

    // Access Codes
    match /access_codes/{code} {
      allow read: if isAuthenticated() && (resource.data.redeemedBy == request.auth.token.email || isAdmin());
      allow create, update, delete: if isAdmin();
    }
    
    // Settings
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
